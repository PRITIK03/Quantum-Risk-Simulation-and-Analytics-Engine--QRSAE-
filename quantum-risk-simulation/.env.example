VITE_PICO_API_KEY=
VITE_LLM_API_URL=
VITE_IMAGE_API_URL=
# Optional: enable client-side logging for debugging (false in production)
VITE_ENABLE_CLIENT_LOGS=false
# Environment Variables
# Copy this file to .env.local and add your actual API keys. DO NOT commit secrets.

# Example (do NOT commit real values):
# VITE_PICO_API_KEY=your_api_key_here
# VITE_LLM_API_URL=https://your-proxy.example.com/llm
# VITE_IMAGE_API_URL=https://your-proxy.example.com/image

# Recommended: do NOT place secret API keys in client-side env vars.
# Instead, create a backend/proxy endpoint and set VITE_LLM_API_URL to that endpoint.
